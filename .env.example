# OpenClaw Skill Forge — Environment
# Copy to .env and add your keys. Never commit .env.

# === LLM (cloud, no local CPU) ===
# Groq — free, reliable. Get key at https://console.groq.com (recommended)
GROQ_API_KEY=
# Chutes API — alternative
CHUTES_API_KEY=
CHUTES_BASE_URL=https://api.chutes.ai
CHUTES_MODEL=meta-llama/Llama-3.1-8B-Instruct

# === PAID ===
OPENAI_API_KEY=

# LLM: chutes | groq | ollama | openai (default: chutes)
LLM_PROVIDER=chutes

# === OpenClaw Gateway (for full agent: tools, skills) ===
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
# Enable in ~/.openclaw/openclaw.json: gateway.http.endpoints.chatCompletions.enabled: true
